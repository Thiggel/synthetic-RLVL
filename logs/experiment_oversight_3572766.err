#!/usr/bin/env bash
# Hard-v3 reward ablation. Requires hard-v3 SFT checkpoints to be pre-merged.
# Submit:
#   sbatch --dependency=afterok:<merge_sft_jobid> --array=0-14%2 scripts/slurm/sweeps/posttrain_hard_v3_reward_ablation.slurm

#SBATCH --job-name=posttrain_hard_v3_reward
#SBATCH --partition=a100
#SBATCH --constraint=a100_80
#SBATCH --gres=gpu:a100:1
#SBATCH --cpus-per-task=12
#SBATCH --time=24:00:00
#SBATCH --array=0-14%2
#SBATCH --output=logs/%x_%A_%a.out
#SBATCH --error=logs/%x_%A_%a.err

set -euo pipefail
cd "${SLURM_SUBMIT_DIR:-$PWD}"
mkdir -p logs
source ./scripts/env.sh

VENV_PATH="${VENV_PATH:-${HPCVAULT:-}/.venv_rlvl_posttrain}"
if [[ -z "${HPCVAULT:-}" || ! -x "${VENV_PATH}/bin/python" ]]; then
  VENV_PATH="${WORK}/.venv"
fi
export VIRTUAL_ENV="${VENV_PATH}"
export PATH="${VENV_PATH}/bin:${PATH}"
hash -r 2>/dev/null || true

SEEDS=(3407 3408 3409)
SCHEMAS=(
  correct_plus_0p1_format
  correct_plus_valid_plus_0p1_format
  correct_times_valid_plus_0p1_format
  correct_plus_line_valid_plus_0p1_format
  correct_times_line_valid_plus_0p1_format
)

IDX=${SLURM_ARRAY_TASK_ID}
SEED=${SEEDS[$((IDX / ${#SCHEMAS[@]}))]}
SCHEMA=${SCHEMAS[$((IDX % ${#SCHEMAS[@]}))]}
RUN_NAME="rl_hard_v3_${SCHEMA}_seed${SEED}_mrg"
GROUP="posttrain_hard_v3/${SCHEMA}"

SFT_CHECKPOINT_DEFAULT="${WORK}/synthetic-RLVL/tmp/merged_sft_hard_v3_seed${SEED}"
export SFT_CHECKPOINT="${SFT_CHECKPOINT:-${SFT_CHECKPOINT_DEFAULT}}"
if [[ ! -f "${SFT_CHECKPOINT}/config.json" ]]; then
  echo "Missing hard-v3 merged SFT checkpoint: ${SFT_CHECKPOINT}" >&2
  exit 2
fi

export WANDB_PROJECT="${WANDB_PROJECT:-synthetic-rlvl}"
export WANDB_GROUP="${GROUP}"
export WANDB_RUN_GROUP="${GROUP}"
export RAY_raylet_start_wait_time_s="${RAY_raylet_start_wait_time_s:-120}"

if [[ "${STARTUP_STAGGER_SECONDS:-0}" != "0" ]]; then
  STAGGER_INDEX=$((SLURM_ARRAY_TASK_ID - ${STARTUP_STAGGER_BASE_ID:-0}))
  if (( STAGGER_INDEX < 0 )); then
    STAGGER_INDEX=0
  fi
  sleep $((STAGGER_INDEX * STARTUP_STAGGER_SECONDS + RANDOM % ${STARTUP_JITTER_SECONDS:-60}))
else
  sleep $((RANDOM % ${STARTUP_JITTER_SECONDS:-180}))
fi

python posttrain_grpo_verl.py \
  --config-name posttrain_grpo_hard_v3 \
  seed="${SEED}" \
  run_name="${RUN_NAME}" \
  model.path="${SFT_CHECKPOINT}" \
  model.merge_adapter_for_rollout=false \
  reward.schema="${SCHEMA}" \
  logging.project="${WANDB_PROJECT}" \
  data.train_samples="${TRAIN_SAMPLES:-120000}" \
  grpo.train_steps="${TRAIN_STEPS:-1500}" \
  resume.mode="${RESUME_MODE:-auto}"
#!/usr/bin/env bash
# Merge final hard-v3 VERL actor LoRA checkpoints and run full post-hoc pass@k evaluation.
# Submit:
#   sbatch --dependency=afterany:<posttrain_jobid> --array=0-14%2 scripts/slurm/jobs/posthoc_hard_v3_merge_eval_passk_2026-04-30.slurm

#SBATCH --job-name=hard_v3_passk_final
#SBATCH --partition=a100
#SBATCH --constraint=a100_80
#SBATCH --gres=gpu:a100:1
#SBATCH --cpus-per-task=12
#SBATCH --time=12:00:00
#SBATCH --array=0-14%2
#SBATCH --output=logs/%x_%A_%a.out
#SBATCH --error=logs/%x_%A_%a.err

set -euo pipefail
cd "${SLURM_SUBMIT_DIR:-$PWD}"
mkdir -p logs passk_eval/hard_v3 tmp
source ./scripts/env.sh

VENV_PATH="${VENV_PATH:-${HPCVAULT:-}/.venv_rlvl_posttrain}"
if [[ -z "${HPCVAULT:-}" || ! -x "${VENV_PATH}/bin/python" ]]; then
  VENV_PATH="${WORK}/.venv"
fi
export VIRTUAL_ENV="${VENV_PATH}"
export PATH="${VENV_PATH}/bin:${PATH}"
hash -r 2>/dev/null || true

SEEDS=(3407 3408 3409)
SCHEMAS=(
  correct_plus_0p1_format
  correct_plus_valid_plus_0p1_format
  correct_times_valid_plus_0p1_format
  correct_plus_line_valid_plus_0p1_format
  correct_times_line_valid_plus_0p1_format
)

IDX=${SLURM_ARRAY_TASK_ID}
SEED=${SEEDS[$((IDX / ${#SCHEMAS[@]}))]}
SCHEMA=${SCHEMAS[$((IDX % ${#SCHEMAS[@]}))]}
RUN_NAME="rl_hard_v3_${SCHEMA}_seed${SEED}_mrg"
GROUP="posttrain_hard_v3/${SCHEMA}"

echo "[hard-v3-passk] row=${IDX} schema=${SCHEMA} seed=${SEED} run=${RUN_NAME} group=${GROUP}"

RUN_ROOT="${WORK}/synthetic-RLVL/runs/${RUN_NAME}"
ACTOR=""
FINAL_STEP=""
for STEP in 1501 1500; do
  CANDIDATE="${RUN_ROOT}/global_step_${STEP}/actor"
  if [[ -f "${CANDIDATE}/lora_adapter/adapter_config.json" || -f "${CANDIDATE}/adapter_config.json" ]]; then
    ACTOR="${CANDIDATE}"
    FINAL_STEP="${STEP}"
    break
  fi
done

if [[ -z "${ACTOR}" ]]; then
  echo "[hard-v3-passk] missing final actor for ${RUN_NAME}; expected global_step_1500 or 1501. Skipping for oversight/resubmission."
  exit 0
fi

MERGED="${WORK}/synthetic-RLVL/tmp/merged_actor_${RUN_NAME}_final"
OUT="${WORK}/synthetic-RLVL/passk_eval/hard_v3/reward_${RUN_NAME}_passk.json"
SAMPLES_OUT="${WORK}/synthetic-RLVL/passk_eval/hard_v3/reward_${RUN_NAME}_samples.jsonl"

if [[ ! -f "${MERGED}/config.json" || "${FORCE_PASSK_MERGE:-0}" == "1" ]]; then
  rm -rf "${MERGED}.tmp"
  python scripts/merge_lora_checkpoint.py \
    --checkpoint "${ACTOR}" \
    --output "${MERGED}.tmp" \
    --dtype bf16 \
    --overwrite
  rm -rf "${MERGED}"
  mv "${MERGED}.tmp" "${MERGED}"
else
  echo "[hard-v3-passk] using existing merged actor ${MERGED}"
fi

if [[ -s "${OUT}" && "${FORCE_PASSK_EVAL:-0}" != "1" ]]; then
  echo "[hard-v3-passk] output already exists: ${OUT}; skipping eval."
  exit 0
fi

export WANDB_PROJECT="${WANDB_PROJECT:-synthetic-rlvl}"
export WANDB_GROUP="${GROUP}"
export WANDB_RUN_GROUP="${GROUP}"

python scripts/evaluate_checkpoint_passk.py \
  --checkpoint "${MERGED}" \
  --config conf/posttrain_grpo_hard_v3.yaml \
  --profile grpo \
  --backend vllm \
  --step-min 1 \
  --step-max 20 \
  --samples-per-step 20 \
  --num-generations 64 \
  --k-values 1,2,4,8,16,32,64 \
  --temperature 1.0 \
  --max-new-tokens 1024 \
  --batch-size 1024 \
  --gpu-memory-utilization 0.80 \
  --disable-external \
  --collect-samples 8 \
  --output "${OUT}" \
  --samples-output "${SAMPLES_OUT}" \
  --wandb-project "${WANDB_PROJECT}" \
  --wandb-group "${GROUP}" \
  --wandb-run-name "hard_v3_reward_${SCHEMA}_seed${SEED}_passk_step${FINAL_STEP}"

exec
